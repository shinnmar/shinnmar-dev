---

<section class="hero">
  <div class="container hero-content">
    <div class="hero-text">
      <p class="hero-tag text-mono">🌸 hello, world!</p>

      <h1>
        I'm <span class="animated-name">Shirley :)</span>
      </h1>

      <p class="hero-roles">
        Front-End Developer
        <span class="dot">·</span>
        Organizer GDG
        <span class="dot">·</span>
        Speaker
      </p>

      <p class="hero-bio">
        crafting accessible, user-friendly web experiences with a creative eye,
        pixel-perfect detail, and a strong focus on modern web technologies.
      </p>

      <div class="hero-actions">
        <a href="/talks" class="btn btn-primary">see my talks ✦</a>
        <a
          href="https://www.linkedin.com/in/shirleyramos"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <div class="hero-photo">
      <img src="/img/ShirleyRamos_profile.png" alt="Shirley Ramos Martínez" />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(181, 123, 238, 0.15) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(244, 114, 182, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
    position: relative;
    z-index: 1;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 600px;
  }

  .hero-tag {
    color: var(--color-lila-soft);
    font-size: var(--text-lg);
    letter-spacing: 0.1em;
  }

  .hero-roles {
    font-size: var(--text-lg);
    line-height: 1.5rem;
    color: #ccbdf7;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .dot {
    color: var(--color-lila);
  }

  .hero-bio {
    font-size: var(--text-lg);
    color: var(--color-text);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-photo {
    flex-shrink: 0;
    width: 420px;
    height: 420px;
    border-radius: 40% 60% 55% 45% / 45% 45% 55% 55%;
    border: 2px solid var(--color-lila);
    box-shadow: var(--glow-lila);
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 990px) {
    .hero-photo {
      width: 300px;
      height: 300px;
    }

    .hero-photo img {
      transform: scale(1.08);
    }

    .hero-text {
      text-align: left;
    }
  }

  .badge-ring {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: spin 18s linear infinite;
    background: radial-gradient(
      circle,
      var(--color-surface) 60%,
      transparent 100%
    );
    box-shadow: var(--glow-lila);
  }

  .badge-text {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    clip-path: circle(50%);
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 990px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }

    .hero-roles {
      justify-content: left;
    }


    .hero-badge {
      width: 150px;
      height: 150px;
    }

    .badge-ring {
      width: 150px;
      height: 150px;
    }
  }
</style>
